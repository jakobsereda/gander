|| This is an enum (sum type)
# Job {
    Programmer,
    Artist,
    Doctor,
    Mechanic
}

Job::Artist

|| This is a struct (product type)
$ Person {
    age: Int,
    name: String,
    job: Job
}

Person jake = { 20, "Jake", Job::Programmer }

|| Primitive data types
Int
Float
Bool
String
|| Func (let's do higher order functions later...)

|| Let's just do explicitly typed for now
Int b = 3;

@ foo(Int a) -> Int {
    a + 4
}

foo(b)
